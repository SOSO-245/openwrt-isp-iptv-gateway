read_body(){
  [ "${body_cached:-0}" = "1" ] && { printf '%s' "$body_cache"; return; }
  len="${CONTENT_LENGTH:-0}"
  body_cache=$([ "$len" -gt 0 ] 2>/dev/null && dd bs=1 count="$len" 2>/dev/null || true)
  body_cached=1
  printf '%s' "$body_cache"
}
