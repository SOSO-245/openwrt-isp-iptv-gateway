lan_ip(){
  ipaddr="$(uci -q get network.lan.ipaddr 2>/dev/null || true)"
  [ -n "$ipaddr" ] || ipaddr="$(sed -n '1{s/[[:space:]]//g;p;q}' /etc/soso-iptv-lan-ip 2>/dev/null)"
  [ -n "$ipaddr" ] || ipaddr="$(ip -4 addr show br-lan 2>/dev/null | awk '/inet /{print $2; exit}' | cut -d/ -f1)"
  [ -n "$ipaddr" ] || ipaddr="192.168.1.1"
  printf '%s' "$ipaddr"
}
