  [ -n "$name$logo" ] || return 0
  changed=0
  for f in /www/new.m3u /www/tv.m3u; do
    [ -f "$f" ] || continue
    tmp="$f.tmp.$$"
    awk -v addr="$addr" -v name="$name" -v logo="$logo" '
      function enrich(line) {
        if (name != "") {
          if (line ~ /tvg-name="/) gsub(/tvg-name="[^"]*"/, "tvg-name=\"" name "\"", line)
          else sub(/^#EXTINF:-1/, "#EXTINF:-1 tvg-name=\"" name "\"", line)
          sub(/,[^,]*$/, "," name, line)
        }
        return line
      }
      {
        if (prev != "") {
          if (index($0, addr) > 0) {
            print enrich(prev)
            print
            prev=""
            changed=1
            next
          }
          print prev
          prev=""
        }
        if ($0 ~ /^#EXTINF/) { prev=$0; next }
        print
      }
      END { if (prev != "") print prev; if (changed) exit 7 }
    ' "$f" > "$tmp"
    rc=$?
    mv "$tmp" "$f"
    [ "$rc" = 7 ] && changed=$((changed+1))
  done
  [ "$changed" -gt 0 ] && return 0 || return 1
}
