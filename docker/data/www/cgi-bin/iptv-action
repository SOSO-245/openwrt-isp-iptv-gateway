    sleep 1
    capture_running && log "切台手动抓频道已启动：$iface。请在 IPTV 盒子上切换缺失频道，每个频道停留 3-5 秒；右侧状态会实时显示已抓到的组播地址数量。" || { log "抓包启动失败"; cat $capture_err 2>/dev/null; cat $capture_meta_err 2>/dev/null; } ;;
  capture_status)
    iface=$(cat /etc/iptv-capture-iface 2>/dev/null)
    [ -n "$iface" ] || iface=$(uci -q get network.wan.device || echo eth1)
    running=no
    capture_running && running=yes
    tmp=$trash_dir/capture-live-addrs.txt
    capture_addrs > "$tmp"
    count=$(wc -l < "$tmp" 2>/dev/null | tr -d ' ')
    latest=$(tail -1 "$tmp" 2>/dev/null)
    meta_name=$(capture_name)
    meta_logo=$(capture_logo)
    started=""
    [ -s "$capture_log" ] && started=$(ls -l --time-style=long-iso "$capture_log" 2>/dev/null | awk '{print $6" "$7}')
    log "切台手动抓频道状态"
    echo "状态：$([ "$running" = yes ] && echo 运行中 || echo 未运行)"
    echo "抓包口：$iface"
    [ -n "$started" ] && echo "开始时间：$started"
    echo "已抓到组播地址：${count:-0} 个"
    [ -n "$latest" ] && echo "最新地址：$latest"
    [ -n "$meta_name" ] && echo "频道名称候选：$meta_name"
    [ -n "$meta_logo" ] && echo "台标资源候选：$meta_logo"
    if [ -s "$tmp" ]; then
      echo
      echo "已发现地址（最近 20 个）："
      tail -20 "$tmp"
    else
      echo
      echo "还没发现组播地址。请确认盒子正在播放直播频道，并切换到缺失频道停留 3-5 秒。"
    fi ;;
  stop_capture)
    [ -s $capture_pid ] && kill "$(cat $capture_pid)" 2>/dev/null || true
    [ -s $capture_meta_pid ] && kill "$(cat $capture_meta_pid)" 2>/dev/null || true
    rm -f $capture_pid $capture_meta_pid
    log "已停止，开始分析原始组播流量..."
    tmp=$capture_addrs_txt
    capture_addrs > "$tmp"
    meta_logo=$(capture_logo)
    meta_name=$(capture_name)
    total=$(wc -l < "$tmp" 2>/dev/null | tr -d ' ')
    log "本次抓到可用组播地址：${total:-0} 个"
    [ -n "$meta_name" ] && log "识别到频道名称候选：$meta_name" || log "未识别到明文频道名称"
    [ -n "$meta_logo" ] && log "识别到台标资源候选：$meta_logo" || log "未识别到明文台标资源"
    added=0
    existed=0
    enriched=0
    logo_updates=$trash_dir/capture-logo-updates.$$
    : > "$logo_updates"
    if [ ! -s "$tmp" ]; then
      echo "没有解析到 UDP 组播频道地址。请确认抓包期间 IPTV 设备或播放器有切换/播放频道。"
      echo "说明：被动抓包只能看到已经有设备请求并正在传输的组播流，运营商未推送的频道不会自动出现。"
      exit 0
    fi
    echo "候选地址："
    cat "$tmp"
    echo
    echo "差异分析："
    while read -r addr; do
      [ -n "$addr" ] || continue
      current_name="$meta_name"
      [ -n "$current_name" ] || current_name=$(playlist_name_for_addr "$addr")
      current_logo="$meta_logo"
      [ -n "$current_logo" ] || current_logo=$(epg_logo_for_name "$current_name")
      if playlist_has_addr "$addr"; then
        existed=$((existed+1))
        if update_playlist_metadata "$addr" "$current_name" "$current_logo"; then
          enriched=$((enriched+1))
          echo "已存在并更新元数据：$addr"
        else
          echo "已存在：$addr"
        fi
      else
        append_captured_channel "$addr" rtp "$current_name" "$current_logo"
        added=$((added+1))
        echo "新增并写入 new.m3u：$addr"
      fi
      [ -n "$current_logo" ] && echo "$addr|$current_logo" >> "$logo_updates"
    done < "$tmp"
    if [ "$added" -gt 0 ] || [ "$enriched" -gt 0 ]; then
      tpl='https://live.fanmingming.com/tv/{name}.png'
      strip_m3u_logos /www/new.m3u
      decorate /www/new.m3u /www/new-logo.m3u "$tpl"
      [ -f /www/tv.m3u ] && decorate /www/tv.m3u /www/tv-logo.m3u "$tpl"
      while IFS='|' read -r addr logo; do
        update_logo_metadata "$addr" "$logo" >/dev/null 2>&1 || true
      done < "$logo_updates"
      log "已重新生成带台标节目单：/www/new-logo.m3u"
    fi
    rm -f "$logo_updates"
    log "完成：新增 $added 个，已存在 $existed 个，更新台标/频道名 $enriched 个。"
    playlist_counts ;;
  save_channel)
    name=$(get name); addr=$(get addr); proto=$(get proto); logo=$(get logo); logoTpl=$(get logoTpl); file=$(get file)
    [ -n "$name" ] || { echo "频道名称为空"; exit 0; }; [ -n "$addr" ] || { echo "组播地址为空"; exit 0; }
    [ -n "$proto" ] || proto=rtp; [ "$file" = tv ] || file=new; [ -n "$logoTpl" ] || logoTpl='https://live.fanmingming.com/tv/{name}.png'
    id=$(echo "$name" | tr -d ' -'); [ -n "$logo" ] || logo=$(echo "$logoTpl" | sed "s#{name}#$id#g")
    m3u="/www/$file.m3u"; txt="/www/$file.txt"; url="$(udpxy_base)/$proto/$addr"
    grep -Fq "$url" "$m3u" 2>/dev/null && { echo "已存在：$url"; exit 0; }
    printf '#EXTINF:-1 tvg-id="%s" tvg-name="%s",%s\n%s\n' "$id" "$name" "$name" "$url" >> "$m3u"
    printf '%s,%s\n' "$name" "$url" >> "$txt"
    if [ "$file" = "new" ]; then
      strip_m3u_logos /www/new.m3u
      rebuild_new_logo
      update_logo_metadata "$addr" "$logo" >/dev/null 2>&1 || true
    fi
    log "已保存频道：$name -> $url" ;;
  apply_iptv)
    iface=$(get iface); proto=$(get proto); mac=$(get mac); hostname=$(get hostname); vendorid=$(get vendorid); clientid=$(get clientid); user=$(get pppoeUser); pass=$(get pppoePass)
    [ -n "$iface" ] || iface=eth1; [ -n "$proto" ] || proto=dhcp
    log "应用 IPTV 接口：$iface / $proto"
    uci set network.wan.device="$iface"; uci set network.wan.proto="$proto"; uci set network.wan.defaultroute='0'; uci set network.wan.peerdns='0'
    [ -n "$mac" ] && uci set network.wan.macaddr="$mac" || uci -q delete network.wan.macaddr
    [ -n "$hostname" ] && uci set network.wan.hostname="$hostname" || uci -q delete network.wan.hostname
    [ -n "$vendorid" ] && uci set network.wan.vendorid="$vendorid" || uci -q delete network.wan.vendorid
    [ -n "$clientid" ] && uci set network.wan.clientid="$clientid" || uci -q delete network.wan.clientid
    if [ "$proto" = pppoe ]; then [ -n "$user" ] && uci set network.wan.username="$user"; [ -n "$pass" ] && uci set network.wan.password="$pass"; else uci -q delete network.wan.username; uci -q delete network.wan.password; fi
    uci commit network; ifup wan >$ifup_log 2>&1 || true; restart_proxy; cat $ifup_log ;;
  check_no_proxy)
    log "组播路由检测"; ip route get 239.21.1.120 2>/dev/null || true
    echo; log "Nikki/OpenClash 代理接口检测"; ip route get 239.21.1.120 2>/dev/null | grep -q nikki && echo "警告：可能走 nikki" || echo "正常：未走 nikki，按路由应从 IPTV 接口处理"
    echo; log "防火墙 IPTV 组播规则计数"; nft list chain inet fw4 input_wan 2>/dev/null | grep -E 'IPTV-Multicast-In|DoS UDP' ;;
  fix_multicast_proxy)
    log "修复组播被透明代理(Nikki/OpenClash)..."
    echo "修复前：$(ip route get 239.21.1.120 2>/dev/null | head -1)"
    if [ -z "$(uci -q get network.iptv_mcast_239)" ]; then
      uci set network.iptv_mcast_239='route' 2>/dev/null || true
      uci set network.iptv_mcast_239.interface='wan' 2>/dev/null || true
      uci set network.iptv_mcast_239.target='239.0.0.0' 2>/dev/null || true
      uci set network.iptv_mcast_239.netmask='255.0.0.0' 2>/dev/null || true
      uci commit network 2>/dev/null || true
    fi
    for net in 239.0.0.0/8 224.0.0.0/4; do
      while ip rule del to "$net" 2>/dev/null; do :; done
      ip rule add to "$net" lookup main pref 999 2>/dev/null || true
      ip route replace "$net" dev br-iptv scope link 2>/dev/null || true
    done
    ip route flush cache 2>/dev/null || true
    sleep 1
    after=$(ip route get 239.21.1.120 2>/dev/null | head -1)
    echo "修复后：$after"
    if echo "$after" | grep -q nikki; then
      echo "⚠ 仍可能走代理：请在 Nikki/OpenClash 里把 239.0.0.0/8、224.0.0.0/4 加入直连/绕过(bypass)名单。"
    else
      echo "✓ 组播已强制直连 br-iptv（高优先级 ip rule + 专用路由），未走代理。"
    fi
    log "组播代理修复完成。" ;;
  *) echo "未知动作: $action" ;;
esac
