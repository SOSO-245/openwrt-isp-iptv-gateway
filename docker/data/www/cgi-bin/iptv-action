history_limit(){
  n=$(cat "$history_count_file" 2>/dev/null)
  case "$n" in 3|4|5|6|7|8|9|10) echo "$n" ;; *) echo 5 ;; esac
}
backup_playlist(){
  file="$1"
  [ -f "/www/$file" ] || return 0
  mkdir -p "$history_dir"
  ts=$(date '+%Y%m%d-%H%M%S')
  cp "/www/$file" "$history_dir/$file.$ts.bak" 2>/dev/null || return 0
  limit=$(history_limit)
  ls -1t "$history_dir/$file".*.bak 2>/dev/null | awk -v keep="$limit" 'NR>keep{print}' | while read -r old; do rm -f "$old"; done
}
strip_m3u_logos(){
  file="$1"
  [ -f "$file" ] || return 0
  tmp="$file.tmp.$$"
  awk '
    /^#EXTINF/ {
      gsub(/[[:space:]]*tvg-logo="[^"]*"/, "", $0)
      print
      next
    }
    { print }
  ' "$file" > "$tmp" && mv "$tmp" "$file"
}
strip_m3u_logos_to(){
  src="$1"; dst="$2"
  [ -f "$src" ] || return 0
  tmp="$dst.tmp.$$"
  awk '
    /^#EXTINF/ {
      gsub(/[[:space:]]*tvg-logo="[^"]*"/, "", $0)
      print
      next
    }
    { print }
  ' "$src" > "$tmp" && mv "$tmp" "$dst"
}
ensure_ubus_socket_links(){
  mkdir -p /var/run/ubus 2>/dev/null || true
  if [ -S /var/run/ubus/ubus.sock ]; then
    [ -e /var/run/ubus.sock ] || ln -s /var/run/ubus/ubus.sock /var/run/ubus.sock 2>/dev/null || true
  elif [ -S /var/run/ubus.sock ]; then
    [ -e /var/run/ubus/ubus.sock ] || ln -s ../ubus.sock /var/run/ubus/ubus.sock 2>/dev/null || true
  fi
}
restart_higo_auth_services(){
  for svc in higoros higoos higoros-api higoos-api higo-api; do
    [ -x "/etc/init.d/$svc" ] && "/etc/init.d/$svc" restart >/dev/null 2>&1 && echo "$svc: restarted"
  done
}
probe_url(){ curl -m "${2:-5}" -fsS "$1" -o /dev/null 2>&1; }
tune_udpxy_config(){
  uci set udpxy.@udpxy[0].buffer_size='131072' 2>/dev/null || true
  uci set udpxy.@udpxy[0].buffer_messages='2048' 2>/dev/null || true
  uci set udpxy.@udpxy[0].buffer_time='10' 2>/dev/null || true
  uci set udpxy.@udpxy[0].max_clients='12' 2>/dev/null || true
  refresh_udpxy_source >/dev/null 2>&1 || true
  uci commit udpxy 2>/dev/null || true
}
current_iptv_ip(){
  ip=$(ip -4 -o addr show br-iptv 2>/dev/null | sed -n 's#.* inet \([0-9.]*\)/.*#\1#p' | head -1)
  [ -n "$ip" ] && { echo "$ip"; return; }
  ifstatus wan 2>/dev/null | jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null
}
current_lan_gateway(){
  gw=$(ip route show default dev br-lan 2>/dev/null | awk '/^default /{print $3; exit}')
  [ -n "$gw" ] || gw=$(uci -q get network.lan.gateway)
  [ -n "$gw" ] || gw=192.168.50.1
  echo "$gw"
}
refresh_udpxy_source(){
  ip=$(current_iptv_ip)
  [ -n "$ip" ] || ip=$(ip -4 -o addr show "$(get_iptv_input_iface)" 2>/dev/null | sed -n 's#.* inet \([0-9.]*\)/.*#\1#p' | head -1)
  [ -n "$ip" ] || return 1
  uci set udpxy.@udpxy[0].source="$ip" 2>/dev/null || true
  uci set udpxy.@udpxy[0].bind="$(lan_ip)" 2>/dev/null || true
  uci set udpxy.@udpxy[0].port='12123' 2>/dev/null || true
  uci commit udpxy 2>/dev/null || true
  echo "$ip"
}
repair_network(){
  uci set network.wan.defaultroute='0' 2>/dev/null || true
  uci set network.wan.peerdns='0' 2>/dev/null || true
  uci set network.wan.metric='500' 2>/dev/null || true
  if [ -z "$(uci -q get network.iptv_mcast_239)" ]; then
    uci set network.iptv_mcast_239='route' 2>/dev/null || true
  fi
  uci set network.iptv_mcast_239.interface='wan' 2>/dev/null || true
  uci set network.iptv_mcast_239.target='239.0.0.0' 2>/dev/null || true
  uci set network.iptv_mcast_239.netmask='255.0.0.0' 2>/dev/null || true
  uci set network.iptv_mcast_239.metric='500' 2>/dev/null || true
  uci commit network 2>/dev/null || true
  iptv_if=$(get_iptv_input_iface); box_if=$(get_capture_iface)
  ip link set "$iptv_if" up 2>/dev/null || true
  ip link set "$box_if" up 2>/dev/null || true
  configure_iptv_bridge "$iptv_if" "$box_if" >/dev/null 2>&1 || true
  ip route show default dev br-iptv 2>/dev/null | while read -r line; do
    [ -n "$line" ] && ip route del $line 2>/dev/null || true
  done
  ip route show 224.0.0.0/4 2>/dev/null | while read -r line; do
    [ -n "$line" ] && ip route del $line 2>/dev/null || true
  done
  ip route show 239.0.0.0/8 2>/dev/null | while read -r line; do
    echo "$line" | grep -q 'proto static' && continue
    [ -n "$line" ] && ip route del $line 2>/dev/null || true
  done
  lan_gw=$(current_lan_gateway)
  if ip route show default dev br-lan 2>/dev/null | grep -q '^default '; then
    if ip route show default dev br-lan 2>/dev/null | grep -q 'proto static'; then
      ip route del default via "$lan_gw" dev br-lan metric 10 2>/dev/null || true
    fi
  else
    ip route replace default via "$lan_gw" dev br-lan metric 10 2>/dev/null || true
  fi
  ip route replace 239.0.0.0/8 dev br-iptv metric 500 2>/dev/null || true
  if [ "$(cat /etc/soso-iptv-mode 2>/dev/null)" = "udpxy" ] && [ "$(uci -q get udpxy.@udpxy[0].disabled)" != "1" ]; then
    stop_tc_bridge 2>/dev/null || true
    refresh_udpxy_source >/dev/null 2>&1 || true
    restart_proxy
  else
    /etc/init.d/iptv-tc-bridge restart >/dev/null 2>&1 || true
  fi
}
get_iptv_input_iface(){
  iface=$(cat "$iptv_input_file" 2>/dev/null)
  [ -n "$iface" ] || iface=eth1
  echo "$iface"
}
get_capture_iface(){
  iface=$(cat "$capture_iface_file" 2>/dev/null)
  [ -n "$iface" ] || iface=eth2
  echo "$iface"
}
iface_exists(){ [ -d "/sys/class/net/$1" ]; }
is_usb_iface(){
  iface="$1"
  dev=$(readlink -f "/sys/class/net/$iface/device" 2>/dev/null)
  echo "$dev" | grep -q '/usb'
}
first_usb_iface(){
  for p in /sys/class/net/*; do
    iface=$(basename "$p")
    case "$iface" in lo|br-*|docker*|veth*|ifb*|nikki*) continue ;; esac
    is_usb_iface "$iface" && { echo "$iface"; return; }
  done
}
iface_state_line(){
  iface="$1"
  state=$(cat "/sys/class/net/$iface/operstate" 2>/dev/null || echo missing)
  carrier=$(cat "/sys/class/net/$iface/carrier" 2>/dev/null || echo "-")
  mac=$(cat "/sys/class/net/$iface/address" 2>/dev/null || echo "-")
  driver=$(basename "$(readlink -f "/sys/class/net/$iface/device/driver" 2>/dev/null)" 2>/dev/null)
  [ -n "$driver" ] || driver="-"
  printf '%s state=%s carrier=%s mac=%s driver=%s\n' "$iface" "$state" "$carrier" "$mac" "$driver"
}
configure_iptv_bridge(){
  iptv_if="$1"; box_if="$2"
  [ -n "$iptv_if" ] || iptv_if=$(get_iptv_input_iface)
  [ -n "$box_if" ] || box_if=$(get_capture_iface)
  [ "$iptv_if" = "$box_if" ] && { echo "IPTV 入口和盒子/USB 口不能相同：$iptv_if"; return 1; }
  iface_exists "$iptv_if" || { echo "IPTV 入口不存在：$iptv_if"; return 1; }
  iface_exists "$box_if" || { echo "盒子/USB 网口不存在：$box_if"; return 1; }
  echo "$iptv_if" > "$iptv_input_file"
  echo "$box_if" > "$capture_iface_file"
  uci set network.iptvbr='device' 2>/dev/null || true
  uci set network.iptvbr.name='br-iptv' 2>/dev/null || true
