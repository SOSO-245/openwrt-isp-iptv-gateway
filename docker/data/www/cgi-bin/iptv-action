enrich_playlist_logos(){
  file="$1"
  [ -f "$file" ] || return 0
  tmp="$file.tmp.$$"
  count_file="$trash_dir/logo-enrich-count.$$"
  echo 0 > "$count_file"
  awk -v count_file="$count_file" -v ver="$(date +%s)" '
    function shquote(s) { gsub(/\047/, "\047\\\047\047", s); return "\047" s "\047" }
    function cmd_logo(name,  cmd, out) {
      cmd="/www/cgi-bin/iptv-action-logo-helper " shquote(name)
      cmd | getline out
      close(cmd)
      return out
    }
    /^#EXTINF/ {
      line=$0
      name=line
      sub(/^.*,/,"",name)
      if ((line !~ /tvg-logo="/ || line ~ /live[.]fanmingming[.]com/) && name != "") {
        logo=cmd_logo(name)
        if (logo != "") {
          if (line ~ /tvg-logo="/) gsub(/tvg-logo="[^"]*"/, "tvg-logo=\"" logo "?v=" ver "\"", line)
          else sub(/^#EXTINF:-1/, "#EXTINF:-1 tvg-logo=\"" logo "?v=" ver "\"", line)
          system("n=$(cat " count_file "); echo $((n+1)) > " count_file)
        } else if (line ~ /live[.]fanmingming[.]com/) {
          gsub(/[[:space:]]*tvg-logo="[^"]*"/, "", line)
          system("n=$(cat " count_file "); echo $((n+1)) > " count_file)
        }
      }
      print line
      next
    }
    { print }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
  cat "$count_file" 2>/dev/null || echo 0
  rm -f "$count_file"
}
build_local_logos(){
  # $1 基础m3u(源)  $2 目标m3u；并发探测本地台标库，给匹配到的频道写 tvg-logo，输出匹配数
  src="$1"; dst="$2"; force="$3"
  host="$(configured_epg_host)"
  base=""
  [ -n "$host" ] && base="http://$host:8080/data/icon"
  lan="$(lan_ip)"
  cachedir=/www/iptv/logos
  mkdir -p "$cachedir"
  ver=$(date +%s)
  work="$trash_dir/logowork.$$"; rm -rf "$work"; mkdir -p "$work"
  awk -F',' '/^#EXTINF/{n=$0; sub(/^.*,/,"",n); if(n!="") print n}' "$src" | sort -u > "$work/names.txt"
  i=0
  while IFS= read -r nm; do
    [ -n "$nm" ] || continue
    i=$((i+1))
    (
      key=$(printf '%s' "$nm" | md5sum | cut -c1-16)
      placeholder=0
      [ -s "$cachedir/$key.png" ] && is_placeholder_logo "$cachedir/$key.png" && placeholder=1
      # 非强制同步时：本地图标库已有(含手动上传/替换)则直接复用，不再访问 NAS
      if [ "$force" != 1 ]; then
        if [ -s "$cachedir/$key.png" ] && ! is_placeholder_logo "$cachedir/$key.png"; then printf '%s\t%s.png\n' "$nm" "$key" > "$work/r.$i"; exit 0; fi
      fi
      if [ -n "$base" ]; then
        logo_candidate_names "$nm" | awk 'NF && !seen[$0]++' > "$work/cand.$i"
        while IFS= read -r candname; do
          [ -n "$candname" ] || continue
          for ext in png jpg jpeg webp gif; do
            cand="$candname.$ext"
            if curl -s -m4 -fsS "$base/$cand" -o "$work/dl.$i" 2>/dev/null && [ -s "$work/dl.$i" ]; then
              if save_logo_png "$work/dl.$i" "$cachedir/$key.png"; then
                rm -f "$cachedir/$key.svg" "$cachedir/$key.jpg" "$cachedir/$key.jpeg" "$cachedir/$key.webp" "$cachedir/$key.gif"
                clear_placeholder_logo "$cachedir/$key.png"
                printf '%s\t%s.png\n' "$nm" "$key" > "$work/r.$i"
                rm -f "$work/dl.$i"
                exit 0
              fi
            fi
            rm -f "$work/dl.$i"
          done
        done < "$work/cand.$i"
      fi
      if [ "$force" != 1 ] && [ "$placeholder" = 1 ]; then
        printf '%s\t%s.png\n' "$nm" "$key" > "$work/r.$i"
      fi
      rm -f "$work/dl.$i"
    ) &
    [ $((i % 8)) -eq 0 ] && wait
  done < "$work/names.txt"
  wait
  cat "$work"/r.* 2>/dev/null > "$work/map.tsv"
  found=$(wc -l < "$work/map.tsv" 2>/dev/null | tr -d ' ')
  awk -F'\t' -v lan="$lan" -v ver="$ver" '
    NR==FNR{logo[$1]=$2; next}
    /^#EXTINF/{
      line=$0; name=line; sub(/^.*,/,"",name)
      gsub(/[[:space:]]*tvg-logo="[^"]*"/,"",line)
      if(name in logo) sub(/^#EXTINF:-1/,"#EXTINF:-1 tvg-logo=\"http://" lan ":8080/iptv/logos/" logo[name] "?v=" ver "\"",line)
      print line; next
    }
    {print}
  ' "$work/map.tsv" "$src" > "$work/out.m3u"
  mv "$work/out.m3u" "$dst"
  rm -rf "$work"
  echo "${found:-0}"
}
online_fill_logos(){
  # 为本地库尚缺台标的频道，从可选在线台标模板下载到本地库。输出新增数。
  src="$1"
  cachedir=/www/iptv/logos; mkdir -p "$cachedir"
  srcfile=/etc/soso-iptv-logo-sources
  work="$trash_dir/onfill.$$"; rm -rf "$work"; mkdir -p "$work"
  ensure_logo_sources
  grep -vE '^[[:space:]]*#|^[[:space:]]*$' "$srcfile" 2>/dev/null | grep -F '{name}' > "$work/tpls.txt" 2>/dev/null || true
  [ -s "$work/tpls.txt" ] || { rm -rf "$work"; echo 0; return; }
  awk -F',' '/^#EXTINF/{n=$0; sub(/^.*,/,"",n); if(n!="") print n}' "$src" | sort -u > "$work/names.txt"
  i=0
  while IFS= read -r nm; do
    [ -n "$nm" ] || continue
    i=$((i+1))
    (
      key=$(printf '%s' "$nm" | md5sum | cut -c1-16)
      [ -s "$cachedir/$key.png" ] && ! is_placeholder_logo "$cachedir/$key.png" && exit 0
      clean=$(printf '%s' "$nm" | sed 's/[[:space:]]//g;s/[（(].*[）)]//g;s/-//g;s/－//g;s/线路[0-9]*//g;s/4K超高清//g;s/超高清//g;s/4K//g;s/高清//g;s/超清//g;s/标清//g;s/LD//g;s/HD//g;s/IPTV//g;s/频道$//')
      while IFS= read -r tpl; do
        [ -n "$tpl" ] || continue
        pre=${tpl%%"{name}"*}; post=${tpl#*"{name}"}
        for cand in "$nm" "$clean"; do
          [ -n "$cand" ] || continue
          url="$pre$cand$post"
          if curl -sL -m 12 -A "Mozilla/5.0" -fsS "$url" -o "$work/dl.$i" 2>/dev/null && [ -s "$work/dl.$i" ]; then
            if save_logo_png "$work/dl.$i" "$cachedir/$key.png"; then
              rm -f "$cachedir/$key.svg" "$cachedir/$key.jpg" "$cachedir/$key.jpeg" "$cachedir/$key.webp" "$cachedir/$key.gif"
              clear_placeholder_logo "$cachedir/$key.png"
              printf '1\n' > "$work/r.$i"
              exit 0
            fi
          fi
          rm -f "$work/dl.$i"
        done
      done < "$work/tpls.txt"
    ) &
    [ $((i % 6)) -eq 0 ] && wait
  done < "$work/names.txt"
  wait
  filled=$(cat "$work"/r.* 2>/dev/null | wc -l | tr -d ' ')
  rm -rf "$work"
  echo "${filled:-0}"
}
generate_fallback_logos(){
  src="/www/new.m3u"
  [ -f "$src" ] || src="/www/new-logo.m3u"
  [ -f "$src" ] || { echo 0; return; }
  cachedir=/www/iptv/logos
  mkdir -p "$cachedir"
  work="$trash_dir/fallback-logos.$$"; rm -rf "$work"; mkdir -p "$work"
  awk -F',' '/^#EXTINF/{name=$0; sub(/^.*,/,"",name); if(name!="") print name}' "$src" | sort -u > "$work/names.txt"
  added=0
  while IFS= read -r nm; do
    [ -n "$nm" ] || continue
    key=$(printf '%s' "$nm" | md5sum | cut -c1-16)
    [ -s "$cachedir/$key.png" ] && continue
    short=$(printf '%s' "$nm" | sed 's/线路[0-9]*//g;s/高清//g;s/超高清//g;s/标清//g;s/[[:space:]]//g' | cut -c1-8)
    [ -n "$short" ] || short="$nm"
    rm -f "$cachedir/$key.svg" "$cachedir/$key.jpg" "$cachedir/$key.jpeg" "$cachedir/$key.webp" "$cachedir/$key.gif"
    if make_placeholder_png "$cachedir/$key.png"; then mark_placeholder_logo "$cachedir/$key.png"; added=$((added+1)); fi
  done < "$work/names.txt"
  rm -rf "$work"
  echo "$added"
}
normalize_logo_key(){
  printf '%s' "$1" | sed 's/[[:space:]]//g;s/[（(].*[）)]//g;s/-//g;s/－//g;s/线路[0-9]*//g;s/4K超高清//g;s/超高清//g;s/4K//g;s/高清//g;s/超清//g;s/标清//g;s/LD//g;s/HD//g;s/IPTV//g;s/频道$//'
}
ensure_epg_icon_sources(){
  if [ ! -s "$epg_icon_sources_file" ]; then
    cat > "$epg_icon_sources_file" <<'EPGSRCICON'
# 每行一个 XMLTV/EPG 地址。支持 .xml / .xml.gz。
# 只会读取 <channel> 里的 <display-name> 和 <icon src="...">。
# 51zmt 为已在路由器侧验证可生成本地 EPG 的默认源。
http://epg.51zmt.top:8000/e.xml
# 如需读取外部 php-epg/NAS 的台标，可手动追加对应 t.xml.gz 地址。
EPGSRCICON
  fi
  mkdir -p /www/iptv
  grep -vE '^[[:space:]]*#|^[[:space:]]*$' "$epg_icon_sources_file" > /www/iptv/epg-icon-sources.txt 2>/dev/null || true
  host="$(configured_epg_host)"
  if [ -n "$host" ]; then
    local_icon_epg="http://$host:8080/t.xml.gz"
    grep -qxF "$local_icon_epg" /www/iptv/epg-icon-sources.txt 2>/dev/null || echo "$local_icon_epg" >> /www/iptv/epg-icon-sources.txt
  fi
}
extract_epg_icon_map(){
  xml="$1"
  awk '
    BEGIN { RS="</channel>"; ORS="" }
    /<icon/ {
      rec=$0
      icon=""
      if (match(rec, /icon[^>]*src="[^"]+"/)) {
        v=substr(rec,RSTART,RLENGTH)
        sub(/^.*src="/,"",v); sub(/"$/,"",v)
        gsub(/&amp;/,"\\&",v)
        icon=v
      }
      if (icon == "") next
      rec=$0
      seen=0
      while (match(rec, /<display-name[^>]*>[^<]+/)) {
        n=substr(rec,RSTART,RLENGTH)
        sub(/^.*>/,"",n)
        gsub(/^[[:space:]]+|[[:space:]]+$/,"",n)
        if (n != "") { print n "\t" icon "\n"; seen=1 }
        rec=substr(rec,RSTART+RLENGTH)
      }
      if (!seen && match($0, /channel[^>]*id="[^"]+"/)) {
        n=substr($0,RSTART,RLENGTH)
        sub(/^.*id="/,"",n); sub(/"$/,"",n)
        if (n != "") print n "\t" icon "\n"
      }
    }
  ' "$xml"
}
fill_epg_icons(){
  src="/www/new.m3u"
  [ -f "$src" ] || { echo 0; return; }
  ensure_epg_icon_sources
  cachedir=/www/iptv/logos
  mkdir -p "$cachedir"
  work="$trash_dir/epgicons.$$"; rm -rf "$work"; mkdir -p "$work"
  awk -F',' '/^#EXTINF/{n=$0; sub(/^.*,/,"",n); if(n!="") print n}' "$src" | sort -u > "$work/names.txt"
  : > "$work/wanted.tsv"
  while IFS= read -r nm; do
    [ -n "$nm" ] || continue
    printf '%s\t%s\n' "$nm" "$(normalize_logo_key "$nm")" >> "$work/wanted.tsv"
  done < "$work/names.txt"
  : > "$work/epg-map.tsv"
  ok_sources=0
  total_sources=0
  while IFS= read -r epg; do
    [ -n "$epg" ] || continue
    total_sources=$((total_sources+1))
    raw="$work/src.$total_sources.raw"
    xml="$work/src.$total_sources.xml"
    if curl -sL -m 35 -A "Mozilla/5.0" -fsS "$epg" -o "$raw" 2>/dev/null && [ -s "$raw" ]; then
      if gzip -t "$raw" >/dev/null 2>&1; then gzip -dc "$raw" > "$xml" 2>/dev/null || cp "$raw" "$xml"; else cp "$raw" "$xml"; fi
      rows=$(extract_epg_icon_map "$xml" | wc -l | tr -d ' ')
      if [ "${rows:-0}" -gt 0 ]; then
        ok_sources=$((ok_sources+1))
        extract_epg_icon_map "$xml" | while IFS="$(printf '\t')" read -r ch icon; do
          [ -n "$ch" ] && [ -n "$icon" ] || continue
          printf '%s\t%s\t%s\n' "$(normalize_logo_key "$ch")" "$ch" "$icon"
        done >> "$work/epg-map.tsv"
      fi
    fi
  done < /www/iptv/epg-icon-sources.txt
  awk -F'\t' 'NF>=3 && !seen[$1]++ { print }' "$work/epg-map.tsv" > "$work/epg-map.uniq.tsv"
  mv "$work/epg-map.uniq.tsv" "$work/epg-map.tsv"
  cp "$work/epg-map.tsv" /www/iptv/epg-icon-map.tsv 2>/dev/null || true
  added=0
  matched=0
  i=0
  while IFS="$(printf '\t')" read -r nm key; do
    [ -n "$nm" ] || continue
    logo_url=$(awk -F'\t' -v key="$key" '$1==key{print $3; exit}' "$work/epg-map.tsv")
    [ -n "$logo_url" ] || continue
    matched=$((matched+1))
    ckey=$(printf '%s' "$nm" | md5sum | cut -c1-16)
    exists=0
    [ -s "$cachedir/$ckey.png" ] && ! is_placeholder_logo "$cachedir/$ckey.png" && exists=1
    [ "$exists" = 1 ] && continue
    i=$((i+1))
    if curl -sL -m 15 -A "Mozilla/5.0" -fsS "$logo_url" -o "$work/dl.$i" 2>/dev/null && [ -s "$work/dl.$i" ]; then
      sz=$(wc -c < "$work/dl.$i" 2>/dev/null | tr -d ' ')
      if [ "${sz:-0}" -gt 64 ]; then
        if save_logo_png "$work/dl.$i" "$cachedir/$ckey.png"; then
          rm -f "$cachedir/$ckey.svg" "$cachedir/$ckey.jpg" "$cachedir/$ckey.jpeg" "$cachedir/$ckey.webp" "$cachedir/$ckey.gif"
          clear_placeholder_logo "$cachedir/$ckey.png"
          added=$((added+1))
        fi
      fi
    fi
    rm -f "$work/dl.$i"
  done < "$work/wanted.tsv"
  echo "$added|$matched|$ok_sources|$total_sources"
  rm -rf "$work"
}
epg_norm_awk='
function norm(s) {
  gsub(/&amp;/, "\\&", s)
  gsub(/[ \t\r\n]/, "", s)
  gsub(/（[^）]*）/, "", s)
  gsub(/\([^)]*\)/, "", s)
  gsub(/-/, "", s)
  gsub(/－/, "", s)
  gsub(/线路[0-9]*/, "", s)
  gsub(/4K超高清/, "", s)
  gsub(/超高清/, "", s)
  gsub(/4K/, "", s)
  gsub(/高清/, "", s)
  gsub(/超清/, "", s)
  gsub(/标清/, "", s)
  gsub(/LD/, "", s)
  gsub(/HD/, "", s)
  gsub(/IPTV/, "", s)
  gsub(/频道$/, "", s)
  gsub(/专区$/, "", s)
  gsub(/台$/, "", s)
  gsub(/中文国际[美洲欧洲]*/, "", s)
  gsub(/^BTV/, "", s)
  gsub(/卫视$/, "", s)
  return s
}'
update_local_epg(){
  ensure_epg_sources
  ensure_channel_aliases
  command -v python3 >/dev/null 2>&1 || { echo "0|0|0|0|缺少 python3，无法生成本地 EPG"; return; }
  [ -x /usr/bin/soso-epg-gen ] || { echo "0|0|0|0|缺少 /usr/bin/soso-epg-gen"; return; }
  log "开始更新本地 EPG：按当前 M3U tvg-id 重写 XMLTV channel id..."
  result=$(python3 /usr/bin/soso-epg-gen 2>&1)
  ret=$?
  log "本地 EPG 生成器输出：$result"
  channels=$(grep -c '<channel ' /www/epg.xml 2>/dev/null | tr -d ' ')
  programmes=$(grep -c '<programme ' /www/epg.xml 2>/dev/null | tr -d ' ')
  if [ "$ret" = 0 ] && [ "${channels:-0}" -gt 0 ] && [ "${programmes:-0}" -gt 0 ]; then
    echo "${channels:-0}|${programmes:-0}|1|1|OK"
  else
    echo "${channels:-0}|${programmes:-0}|0|0|${result:-本地 EPG 生成失败}"
  fi
}
install_epg_cron(){
  ensure_epg_schedule
  enabled=$(sed -n 's/^enabled=//p' "$epg_schedule_file" | tail -1)
  mkdir -p /etc/crontabs 2>/dev/null || true
  tmp=/tmp/soso-iptv-cron.$$
  [ -f /etc/crontabs/root ] && grep -v 'soso-iptv epg schedule' /etc/crontabs/root > "$tmp" || : > "$tmp"
  if [ "$enabled" = 1 ]; then
    echo "*/10 * * * * QUERY_STRING='action=epg_scheduled_update' /www/cgi-bin/iptv-action >/tmp/iptv/trash/epg-schedule.log 2>&1 # soso-iptv epg schedule" >> "$tmp"
  fi
  mv "$tmp" /etc/crontabs/root
  /etc/init.d/cron restart >/dev/null 2>&1 || true
}
backup_local_epg(){
  ensure_epg_schedule
  . "$epg_schedule_file" 2>/dev/null || true
  keep_days=${keep_days:-14}
  case "$keep_days" in *[!0-9]*|'') keep_days=14 ;; esac
  mkdir -p "$history_dir/epg"
  ts=$(date '+%Y%m%d-%H%M%S')
  [ -f /www/epg.xml.gz ] && cp /www/epg.xml.gz "$history_dir/epg/epg.xml.gz.$ts.bak" 2>/dev/null || true
  find "$history_dir/epg" -type f -name 'epg.xml.gz.*.bak' -mtime +"$keep_days" -delete 2>/dev/null || true
}
run_epg_pipeline(){
  log "开始一站式更新：本地 EPG、在线台标、兜底台标..."
  epg_result=$(update_local_epg)
  icon_result=$(fill_epg_icons)
  online_added=$(online_fill_logos /www/new.m3u)
  fallback_added=$(generate_fallback_logos)
  tmp="$trash_dir/new-logo.pipeline.$$"
  found=$(build_local_logos /www/new.m3u "$tmp")
  backup_playlist new-logo.m3u
  mv "$tmp" /www/new-logo.m3u
  date '+%F %T' > "$epg_last_file"
  log "一站式更新完成：EPG=$epg_result，EPG图标=$icon_result，网络台标=$online_added，兜底台标=$fallback_added，节目单台标=$found。"
  echo "本地 EPG：$epg_result"
  echo "EPG 图标汇总：$icon_result"
  echo "网络台标新增：${online_added:-0}"
  echo "兜底文字台标新增：${fallback_added:-0}"
  echo "new-logo.m3u 当前台标：${found:-0}"
}
epg_pipeline_running(){
  [ -s "$epg_pipeline_pid" ] || return 1
  pid=$(cat "$epg_pipeline_pid" 2>/dev/null)
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}
append_captured_channel(){
  addr="$1"
  proto="$2"
  meta_name="$3"
  meta_logo="$4"
  [ -n "$proto" ] || proto=rtp
  id=$(echo "$addr" | sed 's/[^0-9]/_/g')
  name="${meta_name:-抓包新增-$id}"
  url="$(udpxy_base)/$proto/$addr"
  printf '#EXTINF:-1 tvg-id="%s" tvg-name="%s",%s\n%s\n' "$id" "$name" "$name" "$url" >> /www/new.m3u
  printf '%s,%s\n' "$name" "$url" >> /www/new.txt
}
decorate(){ src="$1"; dst="$2"; tpl="$3"; awk -v tpl="$tpl" '
BEGIN{FS="\n"}
/^#EXTINF/ {
  line=$0
  name=$0
  sub(/^.*,/,"",name)
  id=name
  gsub(/[[:space:]-]/,"",id)
  logo=tpl
  gsub(/\{name\}/,id,logo)
  if (line !~ /tvg-id="/) sub(/^#EXTINF:-1/, "#EXTINF:-1 tvg-id=\"" id "\"", line)
  if (line !~ /tvg-name="/) sub(/^#EXTINF:-1/, "#EXTINF:-1 tvg-name=\"" name "\"", line)
  if (tpl != "" && line !~ /tvg-logo="/) sub(/^#EXTINF:-1/, "#EXTINF:-1 tvg-logo=\"" logo "\"", line)
  print line
  next
}
{print}
' "$src" > "$dst"
}
action=$(get action)
ensure_runtime
case "$action" in
  auth|change_auth|get_theme|get_config|get_playlist|get_history|get_ui_log|get_capture_ui_log|download_boot_capture|epg_scheduled_update|"")
