  clean=$(printf '%s\n' "$raw" | sed 's/[[:space:]]//g;s/[（(].*[）)]//g;s/-//g;s/－//g;s/线路[0-9]*//g;s/4K超高清//g;s/超高清//g;s/4K//g;s/高清//g;s/超清//g;s/标清//g;s/LD//g;s/HD//g;s/IPTV//g;s/频道$//')
  printf '%s\n%s\n' "$raw" "$clean"
  case "$raw" in
    *CCTV*4K*|*CCTV-4K*) echo CCTV4K ;;
  esac
  case "$raw" in
    *CCTV4*美洲*) echo CCTV4美洲 ;;
    *CCTV4*欧洲*) echo CCTV4欧洲; echo CCTV4EUO ;;
    *澳门*Macau*|*Macau*卫视*) echo 澳门卫视 ;;
    *NHK*WORLD*|*NHK-WORLD*) echo NHKWORLD ;;
    *CGTN*英文*纪录*|*CGTN*纪录*) echo CGTN纪录; echo CGTNDOCUMENTARY ;;
    *BTV*纪实*) echo BTV纪实 ;;
    *KAKU*少儿*) echo KAKU少儿 ;;
    *法兰西*24*) echo FRANCE24; echo 法兰西24 ;;
    *欧洲新闻*) echo EURONEWS; echo 欧洲新闻 ;;
  esac
}
logo_candidate_names "$name" | awk 'NF && !seen[$0]++' | while IFS= read -r n; do
  [ -n "$n" ] || continue
