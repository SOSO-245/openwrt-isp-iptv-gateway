    curl -m 2 -fsI "$probe" >/dev/null 2>&1 || curl -m 2 -fs "$probe" -o /dev/null 2>&1 || continue
    echo "$url"
    exit 0
  done
done
HELPER
  chmod 755 /www/cgi-bin/iptv-action-logo-helper
}
